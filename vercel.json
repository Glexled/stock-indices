{
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/minute",
      "destination": "/api/minute.py"
    },
    {
      "source": "/api/kline",
      "destination": "/api/kline.py"
    },
    {
      "source": "/api/realtime",
      "destination": "/api/realtime.py"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
