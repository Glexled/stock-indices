{
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/minute",
      "destination": "/api/minute.py"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
